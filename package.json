{
  "name": "chat-nocontrol",
  "version": "0.1.0-beta.1",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/levi-cm/chat-nocontrol.git"
  },
  "homepage": "https://levi-cm.github.io/chat-nocontrol/",
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "tsx scripts/dev-tailscale.ts",
    "dev:tailscale": "npm run dev",
    "dev:http:tailscale": "vite --host $(tailscale ip -4) --port 5173 --strictPort",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "vite build && npm run test:production-artifacts",
    "benchmark:text-compression": "tsx scripts/benchmark-text-compression.ts",
    "preview": "vite preview",
    "docs:check": "tsx scripts/check-doc-terminology.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "NODE_OPTIONS=--require=./scripts/register-eslint-typescript.cjs eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "unit": "vitest run --coverage",
    "test": "npm run typecheck && npm run lint && npm run format:check && npm run unit",
    "test:primitive-vectors": "vitest run src/tests/unit/primitive-vectors.test.ts && tsx scripts/generate-vectors.ts --verify",
    "test:provider-contract": "tsx scripts/check-crypto-provider-contract.ts",
    "vectors:write": "tsx scripts/generate-vectors.ts --write",
    "vectors:nist-sync": "tsx scripts/sync-nist-mlkem-vector.ts --write",
    "protocol-goldens:write": "tsx scripts/generate-protocol-goldens.ts --write",
    "qr-fixtures:write": "tsx scripts/generate-qr-fixtures.ts --write",
    "test:ppx-golden": "vitest run src/tests/unit/ppxc.test.ts src/tests/unit/ppxv.test.ts src/tests/unit/ppxr.test.ts src/tests/unit/ppxt.test.ts src/tests/unit/ppxf.test.ts src/tests/unit/protocol-goldens.test.ts && tsx scripts/generate-protocol-goldens.ts --verify && tsx scripts/check-ppxf-contract.ts",
    "test:parser-property": "vitest run src/tests/property/parser-roundtrip.property.test.ts",
    "test:parser-fuzz": "vitest run src/tests/property/fuzz-100k.property.test.ts",
    "test:mutations": "vitest run src/tests/property/mutation.property.test.ts",
    "test:truncations": "vitest run src/tests/property/truncation.property.test.ts",
    "test:boundaries": "vitest run src/tests/property/boundary.property.test.ts",
    "test:qr-degradation": "vitest run src/tests/property/qr-degradation.property.test.ts src/tests/unit/scan-worker.test.ts && tsx scripts/generate-qr-fixtures.ts",
    "test:bip39": "vitest run src/tests/unit/recovery-words.test.ts src/tests/property/recovery-roundtrip.property.test.ts",
    "test:storage": "vitest run src/tests/unit/storage.test.ts",
    "test:session-only": "playwright test src/tests/e2e/session-only.spec.ts",
    "test:chunks": "vitest run src/tests/property/file-chunks.property.test.ts",
    "test:order": "vitest run src/tests/unit/file-order.test.ts",
    "test:manifest": "vitest run src/tests/unit/file-manifest.test.ts",
    "test:file-limits": "vitest run src/tests/property/file-boundary.property.test.ts",
    "test:cancel": "playwright test src/tests/e2e/file-cancel.spec.ts",
    "test:memory": "vitest run src/tests/unit/memory-budget.test.ts",
    "test:e2e": "playwright test",
    "test:unknown-sender": "vitest run src/tests/unit/unknown-sender.test.ts",
    "test:accessibility": "playwright test src/tests/accessibility",
    "test:i18n": "vitest run src/tests/unit/i18n.test.ts src/tests/accessibility/i18n.test.ts",
    "test:offline": "playwright test src/tests/release/offline.spec.ts",
    "test:pwa-update-policy": "npm run build && playwright test src/tests/release/pwa-update.spec.ts",
    "test:en-de": "playwright test src/tests/e2e/en-de.spec.ts",
    "test:network-denial": "playwright test src/tests/release/network-denial.spec.ts",
    "test:release": "tsx scripts/package-release.ts && tsx scripts/build-sbom.ts --verify && tsx scripts/verify-release.ts",
    "test:sbom": "tsx scripts/build-sbom.ts --verify",
    "test:reproducibility": "tsx scripts/check-reproducibility.ts",
    "test:dependency-review": "tsx scripts/check-dependencies.ts",
    "test:release-prerequisites": "tsx scripts/check-release-prerequisites.ts",
    "test:production-artifacts": "tsx scripts/production-artifacts.ts dist",
    "release:record-pages-deployment": "tsx scripts/finalize-pages-deployment.ts",
    "test:evidence": "tsx scripts/write-test-report.ts",
    "verify:quality": "npm run docs:check && npm run test && npm run test:primitive-vectors && npm run test:provider-contract && npm run test:ppx-golden && npm run test:parser-property && npm run test:parser-fuzz && npm run test:mutations && npm run test:truncations && npm run test:boundaries && npm run test:qr-degradation && npm run test:bip39 && npm run test:storage && npm run test:session-only && npm run test:chunks && npm run test:order && npm run test:manifest && npm run test:file-limits && npm run test:cancel && npm run test:memory && npm run test:en-de && npm run test:e2e && npm run test:unknown-sender && npm run test:accessibility && npm run test:i18n && npm run test:offline && npm run test:pwa-update-policy && npm run test:network-denial && npm run test:dependency-review && npm run test:evidence",
    "verify:ci": "npm run verify:quality",
    "verify": "npm run verify:quality && npm run test:release-prerequisites && npm run test:release && npm run test:sbom && npm run test:reproducibility"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@noble/post-quantum": "0.6.1",
    "@scure/bip39": "2.2.0",
    "@zxing/browser": "0.2.1",
    "idb": "8.0.3",
    "pdf-lib": "1.17.1",
    "preact": "10.29.7",
    "qrcode": "1.5.4",
    "vite-plugin-pwa": "1.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@preact/preset-vite": "2.10.5",
    "@testing-library/preact": "3.2.4",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.0",
    "@types/qrcode": "1.5.6",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "fake-indexeddb": "6.2.5",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "markdownlint-cli2": "0.23.0",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "typescript-eslint": "8.63.0",
    "typescript-eslint-compiler": "npm:typescript@6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
